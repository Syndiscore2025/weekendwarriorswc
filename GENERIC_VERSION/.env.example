# Wrestling Club CRM - Environment Variables Template
# Copy this file to .env for local development
# Add these variables to Render for production deployment

# ============================================
# GITHUB CONFIGURATION
# ============================================
# Your GitHub Personal Access Token (with 'repo' permissions)
# Get it from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username
REPO_OWNER=YourGitHubUsername

# Your repository name
REPO_NAME=yourrepo

# Branch to use (usually 'main')
REPO_BRANCH=main

# ============================================
# SENDGRID EMAIL CONFIGURATION
# ============================================
# Your SendGrid API Key
# Get it from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# Email address to receive contact form notifications
CONTACT_NOTIFICATION_EMAIL=contact@yourclub.com

# Email address to receive registration notifications
REGISTRATION_NOTIFICATION_EMAIL=registrations@yourclub.com

# Verified sender email (must be verified in SendGrid)
# This is the "From" address that appears in notification emails
VERIFIED_SENDER_EMAIL=noreply@yourclub.com

# ============================================
# OPTIONAL CONFIGURATION
# ============================================
# Port for local development (default: 3000)
PORT=3000

